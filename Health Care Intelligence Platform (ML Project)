# -----------------------------
# Diabetes Prediction
# -----------------------------

if menu == "Diabetes Prediction":

    st.header("Diabetes Prediction")

    pregnancies = st.number_input("Pregnancies")
    glucose = st.number_input("Glucose")
    bp = st.number_input("Blood Pressure")
