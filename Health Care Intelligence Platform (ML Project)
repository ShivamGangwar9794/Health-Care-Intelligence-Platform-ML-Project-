import streamlit as st
import pandas as pd
import numpy as np

from sklearn.model_selection import train_test_split
from sklearn.linear_model import LogisticRegression
from sklearn.ensemble import RandomForestClassifier
from sklearn.cluster import KMeans
from sklearn.metrics import accuracy_score


st.title("Health Care Intelligence Platform")

st.write("Machine Learning Based Disease Prediction System")


# -----------------------------
# Diabetes Prediction Model
# -----------------------------

diabetes_data = pd.read_csv("diabetes.csv")

X_diabetes = diabetes_data.drop("Outcome", axis=1)
y_diabetes = diabetes_data["Outcome"]

X_train_d, X_test_d, y_train_d, y_test_d = train_test_split(
    X_diabetes, y_diabetes, test_size=0.2, random_state=42
)

diabetes_model = LogisticRegression(max_iter=1000)
diabetes_model.fit(X_train_d, y_train_d)

diabetes_accuracy = accuracy_score(
    y_test_d, diabetes_model.predict(X_test_d)
)


# -----------------------------
# Heart Disease Prediction
# -----------------------------

heart_data = pd.read_csv("heart.csv")

X_heart = heart_data.drop("target", axis=1)
y_heart = heart_data["target"]

X_train_h, X_test_h, y_train_h, y_test_h = train_test_split(
    X_heart, y_heart, test_size=0.2, random_state=42
)

heart_model = RandomForestClassifier()
heart_model.fit(X_train_h, y_train_h)

heart_accuracy = accuracy_score(
    y_test_h, heart_model.predict(X_test_h)
)


# -----------------------------
# Sidebar Menu
